{
  "name": "@chainbrawler/contract",
  "version": "0.1.0",
  "description": "Conflux Espace Hardhat Template",
  "homepage": "https://github.com/cfxdevkit/repository-template#readme",
  "bugs": {
    "url": "https://github.com/cfxdevkit/repository-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cfxdevkit/repository-template.git"
  },
  "license": "Apache-2.0",
  "author": "SP",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "build": "hardhat compile",
    "doc": "hardhat docgen",
    "coverage": "SOLIDITY_COVERAGE=true hardhat coverage",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix",
    "format": "prettier --write 'contracts/**/*.sol'",
    "format:check": "prettier --check 'contracts/**/*.sol'",
    "check": "hardhat compile && pnpm lint && prettier --check 'contracts/**/*.sol'",
    "check:fix": "hardhat compile && pnpm lint:fix && prettier --write 'contracts/**/*.sol'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition-viem": "^3.0.3",
    "@nomicfoundation/hardhat-toolbox-viem": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.0",
    "@nomicfoundation/hardhat-viem": "^2.1.0",
    "@types/chai": "^4.2.22",
    "chai": "^4.5.0",
    "ethers": "^5.7.2",
    "hardhat": "^2.22.17",
    "hardhat-docgen": "^1.3.0",
    "hardhat-gas-reporter": "^2.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^2.1.0",
    "solhint": "^6.0.1",
    "solidity-coverage": "^0.8.16",
    "viem": "^2.37.5",
    "vue-loader": "^15.9.8",
    "vue-template-compiler": "^2.7.16"
  },
  "optionalDependencies": {
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "vue-style-loader": "^4.1.3"
  },
  "peerDependencies": {
    "vue": "^2.7.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  }
}
