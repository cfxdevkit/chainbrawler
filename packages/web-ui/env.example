# ChainBrawler Web UI Environment Variables
# Copy this file to .env.local and fill in your API keys

# WalletConnect Project ID (Required)
# Get your project ID from https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# RPC Provider API Keys (Optional - will use demo keys if not provided)
# Alchemy API Key - Get from https://www.alchemy.com/
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Infura API Key - Get from https://infura.io/
VITE_INFURA_API_KEY=your_infura_api_key_here

# Conflux API Key - Get from https://developer.confluxnetwork.org/sdks-and-tools/en/conflux_rpcs
# NOTE: If you hit rate limits, the app will automatically fallback to public RPC endpoints
VITE_CONFLUX_API_KEY=your_conflux_api_key_here

# Example with actual keys (DO NOT commit these to version control):
# VITE_WALLETCONNECT_PROJECT_ID=b4e498515364475312f3eea4265b2180
# VITE_ALCHEMY_API_KEY=alcht_1234567890abcdef
# VITE_INFURA_API_KEY=1234567890abcdef1234567890abcdef
# VITE_CONFLUX_API_KEY=6sgTmSuJbfBH6yp2i1ic4NUbfmjVbAVYFHvA4jPN78W1e123ntVXnukn9UAyZmR56hNGNLPtWZHBDgFY8AyvHDtwu

# RATE LIMIT SOLUTIONS:
# 1. The app automatically uses multiple RPC providers with fallbacks
# 2. If you hit daily limits, remove the API key to use public endpoints
# 3. Consider upgrading to a higher tier Conflux RPC plan
# 4. The app includes rate limiting to prevent excessive requests
